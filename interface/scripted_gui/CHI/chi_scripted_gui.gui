guiTypes = {

	containerWindowType = {
		name = "chi_national_comittee_ui_window"
		orientation = lower_left
		position = { x = 0 y = 0 }
		size = { width = @NC_WINDOW_WIDTH height = @NC_WINDOW_HEIGHT }
		clipping = no

		# BACKGROUND
		background = {
			name = "background"
			quadTextureSprite = "GFX_CHI_nc_bg"
			alwaystransparent = yes
		}

		#BACKGROUND SPOTLIGHT
		background = {
			name = "background_spotlight"
			position = { x=23 y=24 }
			quadTextureSprite="GFX_spotlight_overlay"
			alwaystransparent = yes
		}

		# TITLE
		instantTextBoxType = {
			name = "nc_title"
			orientation = center_up
			position = { x = -280 y = 15 }
			font = "hoi_36header"
			text = "CHI_nc_title"
			format = center
			maxWidth = 560
		}


