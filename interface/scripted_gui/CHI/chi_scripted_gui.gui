### Layout constants ###
@NC_WINDOW_WIDTH = 600
@NC_WINDOW_HEIGHT = 890

# Leader section
@LEADER_Y = 35
@LEADER_PORTRAIT_SIZE = 120

# Committee slots section
@COMMITTEE_Y = 235
@COMMITTEE_WIDTH = 160
@COMMITTEE_HEIGHT = 210

# Selection section
@SELECTION_Y = 465
